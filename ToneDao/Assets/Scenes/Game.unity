  impactEffect: {fileID: 180442492}
  hitStopDuration: 0.15
  shakeStrength: 0.4
  shakeDuration: 0.6
  pauseBeforeFade: 0.5
  pauseAfterFade: 1
  player: {fileID: 786534816}
  subtitles:
  - text: "\u0412 \u043D\u0430\u0447\u0430\u043B\u0435 \u0432\u0440\u0435\u043C\u0435\u043D
      \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0430 \u0432\u0435\u043B\u0438\u043A\u0430\u044F
      \u0431\u043E\u0433\u0438\u043D\u044F \u041D\u044E\u0439\u0432\u0430 \u2013\n\u043C\u0430\u0442\u044C
      \u0432\u0441\u0435\u0433\u043E \u0436\u0438\u0432\u043E\u0433\u043E, \u0445\u0440\u0430\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u0438\u0446\u0430
      \u043C\u0438\u0440\u043E\u0437\u0434\u0430\u043D\u0438\u044F"
    holdDuration: 3.5
    fadeDuration: 0.7
  - text: "\u0418\u0437 \u0436\u0435\u043B\u0442\u043E\u0439 \u0440\u0435\u0447\u043D\u043E\u0439
      \u0433\u043B\u0438\u043D\u044B \u043E\u043D\u0430 \u043B\u0435\u043F\u0438\u043B\u0430
      \u043B\u044E\u0434\u0435\u0439,\n\u0432\u0434\u044B\u0445\u0430\u044F \u0432
      \u043A\u0430\u0436\u0434\u043E\u0433\u043E \u0436\u0438\u0437\u043D\u044C \u0441\u0432\u043E\u0438\u043C\u0438
      \u0440\u0443\u043A\u0430\u043C\u0438"
    holdDuration: 3.5
    fadeDuration: 0.7
  - text: "\u041D\u043E \u0432 \u043C\u0438\u0433, \u043A\u043E\u0433\u0434\u0430
      \u0431\u044B\u043B \u0441\u043E\u0437\u0434\u0430\u043D \u043F\u0435\u0440\u0432\u044B\u0439
      \u0447\u0435\u043B\u043E\u0432\u0435\u043A,\n\u043D\u0435\u0431\u043E \u0441\u043E\u0434\u0440\u043E\u0433\u043D\u0443\u043B\u043E\u0441\u044C..."
    holdDuration: 3
    fadeDuration: 0.7
  - text: "\u0421\u043E\u043B\u043D\u0446\u0435 \u0441\u043E\u0440\u0432\u0430\u043B\u043E\u0441\u044C
      \u0441 \u043D\u0435\u0431\u043E\u0441\u0432\u043E\u0434\u0430\n\u0438 \u0440\u0430\u0437\u043B\u0435\u0442\u0435\u043B\u043E\u0441\u044C
      \u043D\u0430 \u043E\u0441\u043A\u043E\u043B\u043A\u0438"
    holdDuration: 0
    fadeDuration: 0.7
  - text: "\u041C\u0438\u0440 \u043F\u043E\u0433\u0440\u0443\u0437\u0438\u043B\u0441\u044F
      \u0432 \u0445\u043E\u043B\u043E\u0434 \u0438 \u0441\u0435\u0440\u043E\u0441\u0442\u044C.\n\u0421\u0432\u0435\u0442
      \u0443\u0433\u0430\u0441"
    holdDuration: 3
    fadeDuration: 0.7
  - text: "\u0422\u044B \u2013 \u041D\u0438'\u044D\u0440,\n\u0415\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439,
      \u043A\u0442\u043E \u0432\u0438\u0434\u0435\u043B \u044D\u0442\u043E"
    holdDuration: 3.5
    fadeDuration: 0.7
  - text: "\u0412\u0435\u0440\u043D\u0438 \u0441\u043E\u043B\u043D\u0446\u0443 \u0435\u0433\u043E
      \u043E\u0441\u043A\u043E\u043B\u043A\u0438"
    holdDuration: 3.5
    fadeDuration: 0.7
  subtitleColor: {r: 1, g: 0.96, b: 0.85, a: 1}
  subtitleShadow: {r: 0, g: 0, b: 0, a: 0.8}
  subtitleBgColor: {r: 0, g: 0, b: 0, a: 0}
  fontSizeRatio: 0.032
  bottomRatio: 0.12
  widthRatio: 0.65
