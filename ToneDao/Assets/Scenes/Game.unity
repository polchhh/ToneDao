  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9fd2eb0395e3c9945a0229f3ce5cfdf6, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::TutorialManager
  steps:
  - title: "\u0414\u0432\u0438\u0436\u0435\u043D\u0438\u0435"
    instruction: "\u041F\u0440\u043E\u0438\u0437\u043D\u0435\u0441\u0438 \u043F\u0435\u0440\u0432\u044B\u0439
      \u0442\u043E\u043D \u2013 \u0440\u043E\u0432\u043D\u044B\u0439 \u0437\u0432\u0443\u043A
      \xAB\u0430\xBB, \u043A\u0430\u043A \u043F\u0435\u043D\u0438\u0435 \u043E\u0434\u043D\u043E\u0439
      \u043D\u043E\u0442\u044B"
    toneSymbol: "\u0101"
    voiceSample: {fileID: 8300000, guid: 637299590db9c92459c8936a832e3e0f, type: 3}
  - title: "\u041F\u0440\u044B\u0436\u043E\u043A"
    instruction: "\u041F\u0440\u043E\u0438\u0437\u043D\u0435\u0441\u0438 \u0432\u0442\u043E\u0440\u043E\u0439
      \u0442\u043E\u043D \u2013 \u0433\u043E\u043B\u043E\u0441 \u0438\u0434\u0435\u0442
      \u0432\u0432\u0435\u0440\u0445"
    toneSymbol: "\xE1"
    voiceSample: {fileID: 8300000, guid: e50047677b42d4c4eb05ac473a6e6573, type: 3}
  - title: "\u0412\u044B\u0441\u043E\u043A\u0438\u0439 \u043F\u0440\u044B\u0436\u043E\u043A"
    instruction: "\u0422\u0440\u0435\u0442\u0438\u0439 \u0442\u043E\u043D \u2013
      \u0433\u043E\u043B\u043E\u0441 \u0441\u043D\u0430\u0447\u0430\u043B\u0430 \u043F\u0430\u0434\u0430\u0435\u0442,
      \u043F\u043E\u0442\u043E\u043C \u043F\u043E\u0434\u043D\u0438\u043C\u0430\u0435\u0442\u0441\u044F"
    toneSymbol: "\u01CE"
    voiceSample: {fileID: 8300000, guid: 92cba8117837be840aca5daf53e560b1, type: 3}
  - title: "\u0423\u0434\u0430\u0440 \u043E \u0437\u0435\u043C\u043B\u044E"
    instruction: "\u0427\u0435\u0442\u0432\u0435\u0440\u0442\u044B\u0439 \u0442\u043E\u043D
      \u2013 \u0433\u043E\u043B\u043E\u0441 \u0440\u0435\u0437\u043A\u043E \u043F\u0430\u0434\u0430\u0435\u0442
      \u0432\u043D\u0438\u0437"
    toneSymbol: "\xE0"
    voiceSample: {fileID: 8300000, guid: 795a04f69d87d434582ee5fee316d01c, type: 3}
  - title: "\u0412\u0437\u0430\u0438\u043C\u043E\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435
      \u0441 \u043E\u0431\u044A\u0435\u043A\u0442\u0430\u043C\u0438"
    instruction: "\u041F\u043E\u0434\u043E\u0439\u0434\u0438 \u043A \u0441\u0432\u0435\u0442\u044F\u0449\u0435\u043C\u0443\u0441\u044F
      \u043E\u0441\u043A\u043E\u043B\u043A\u0443 \u0441\u043E\u043B\u043D\u0446\u0430.\n\u041A\u043E\u0433\u0434\u0430
      \u0443\u0432\u0438\u0434\u0438\u0448\u044C \u043F\u043E\u0434\u0441\u043A\u0430\u0437\u043A\u0443
      \u2013 \u043D\u0430\u0436\u043C\u0438 E"
    toneSymbol: E
    voiceSample: {fileID: 0}
  - title: "\u0410\u043A\u0442\u0438\u0432\u0438\u0440\u0443\u0439 \u043E\u0431\u044A\u0435\u043A\u0442"
    instruction: "\u041F\u0440\u043E\u0438\u0437\u043D\u0435\u0441\u0438 \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u0435
      \u043E\u0431\u044A\u0435\u043A\u0442\u0430 \u043F\u043E-\u043A\u0438\u0442\u0430\u0439\u0441\u043A\u0438"
    toneSymbol: "\u0418\u0435\u0440\u043E\u0433\u043B\u0438\u0444"
    voiceSample: {fileID: 0}
